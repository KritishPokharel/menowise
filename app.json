{
  "expo": {
    "name": "MenoWise",
    "slug": "menowise",
    "scheme": "menowise",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFF3F7"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ankurgyawali.menowise",
      "runtimeVersion": "1.0.0"
    },
    "android": {
      "package": "com.ankurgyawali.menowise",
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#FFF3F7"
      },
      "runtimeVersion": {
        "policy": "appVersion"
      }
    },
    "plugins": [
      "expo-router"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "b01edda0-a91c-400b-896a-f98f4e9292a6"
      }
    },
    "owner": "ankurgyawali",
    "updates": {
      "url": "https://u.expo.dev/b01edda0-a91c-400b-896a-f98f4e9292a6"
    }
  }
}
